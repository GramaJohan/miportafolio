---
import { profile } from '../../Profile.js';
---

<section id="inicio" class="min-h-screen flex items-center pt-16 bg-gradient-to-br from-white to-blue-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-12">
    <div class="flex-1 text-center md:text-left">
      <h2 class="text-blue-600 font-semibold tracking-wide uppercase text-sm mb-2">Hola, mi nombre es</h2>
      <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 mb-6 tracking-tight">
        {profile.nombre} <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Profesional</span>
      </h1>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl leading-relaxed">
        {profile.titulo}. {profile.sobreMi}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a href="#contacto" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-lg shadow-blue-200">
          Contáctame
        </a>
        <a href="/cv.pdf" download class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          Descargar CV
        </a>
      </div>
    </div>
    <div class="flex-1 relative">
      <div class="w-64 h-64 md:w-80 md:h-80 bg-blue-100 rounded-2xl rotate-3 absolute inset-0 -z-10 animate-pulse"></div>
      <div class="w-64 h-64 md:w-80 md:h-80 bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden flex items-center justify-center">
        <!-- Placeholder image or icon -->
        <svg class="w-32 h-32 text-blue-200" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
      </div>
    </div>
  </div>
</section>
