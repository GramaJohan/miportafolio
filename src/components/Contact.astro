---
import Section from './Section.astro';
import { profile } from '../../Profile.js';
---

<Section id="contacto" title="Contacto" subtitle="¿Tienes algún proyecto en mente o simplemente quieres saludar? ¡Hablemos!">
  <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden max-w-5xl mx-auto flex flex-col md:flex-row">
    <div class="flex-1 bg-blue-600 p-8 md:p-12 text-white">
      <h4 class="text-2xl font-bold mb-8">Información de Contacto</h4>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="bg-blue-500/30 p-2 rounded">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <div>
            <p class="text-blue-100 text-sm">Email</p>
            <p class="font-semibold">{profile.email}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="bg-blue-500/30 p-2 rounded">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <div>
            <p class="text-blue-100 text-sm">Teléfono</p>
            <p class="font-semibold">{profile.telefono}</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="bg-blue-500/30 p-2 rounded">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <p class="text-blue-100 text-sm">Ubicación</p>
            <p class="font-semibold">{profile.ubicacion}</p>
          </div>
        </div>
      </div>
      <div class="mt-12 pt-12 border-t border-blue-500/30">
        <p class="text-blue-100 text-sm mb-4">Sigueme en redes</p>
        <div class="flex gap-4">
          <!-- Add social icons here -->
          <a href="#" class="p-2 bg-blue-500/30 rounded-lg hover:bg-blue-400/30 transition-colors">LinkedIn</a>
          <a href="#" class="p-2 bg-blue-500/30 rounded-lg hover:bg-blue-400/30 transition-colors">GitHub</a>
        </div>
      </div>
    </div>
    <div class="flex-[1.5] p-8 md:p-12">
      <form id="contact-form" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Nombre Completo</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Correo Electrónico</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
          </div>
        </div>
        <div>
          <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">Asunto</label>
          <input type="text" id="subject" name="subject" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all resize-none"></textarea>
        </div>
        <button type="submit" id="submit-btn" class="w-full py-4 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors shadow-lg shadow-blue-100">
          Enviar Mensaje
        </button>
        <!-- Feedback message -->
        <div id="form-feedback" class="hidden text-center py-3 px-4 rounded-lg font-medium transition-all"></div>
      </form>
    </div>
  </div>
</Section>

<script>
  import { supabase } from '../lib/supabaseClient.js';

  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const feedback = document.getElementById('form-feedback');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Disable button and show loading state
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    feedback.classList.add('hidden');

    const nombre = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const asunto = document.getElementById('subject').value.trim();
    const mensaje = document.getElementById('message').value.trim();

    const { error } = await supabase
      .from('contact_messages')
      .insert([{ nombre, email, asunto, mensaje }]);

    if (error) {
      // Show error
      feedback.textContent = '❌ Error al enviar el mensaje. Inténtalo de nuevo.';
      feedback.className = 'text-center py-3 px-4 rounded-lg font-medium bg-red-50 text-red-600 border border-red-200';
    } else {
      // Show success
      feedback.textContent = '✅ ¡Mensaje enviado correctamente! Te responderé pronto.';
      feedback.className = 'text-center py-3 px-4 rounded-lg font-medium bg-green-50 text-green-600 border border-green-200';
      form.reset();
    }

    // Restore button
    submitBtn.disabled = false;
    submitBtn.textContent = 'Enviar Mensaje';
    submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
  });
</script>
