---
import Section from './Section.astro';
import { profile } from '../../Profile.js';

const education = profile.educacion.map(edu => ({
  degree: edu.carrera,
  institution: edu.institucion,
  year: edu.estado
}));
---

<Section id="educacion" title="Formación" subtitle="Mis antecedentes académicos y trayectoria educativa.">
  <div class="max-w-3xl mx-auto">
    <div class="space-y-6">
      {education.map(edu => (
        <div class="p-6 bg-white border border-gray-100 rounded-xl shadow-sm hover:border-blue-200 transition-colors">
          <div class="flex items-start gap-4">
            <div class="bg-blue-50 p-3 rounded-lg text-blue-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path></svg>
            </div>
            <div>
              <h5 class="font-bold text-xl text-gray-900">{edu.degree}</h5>
              <p class="text-blue-600 font-medium">{edu.institution}</p>
              <span class="inline-block mt-2 px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold rounded-full uppercase">
                {edu.year}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Section>
