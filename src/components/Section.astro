---
interface Props {
  id: string;
  title?: string;
  subtitle?: string;
  className?: string;
}

const { id, title, subtitle, className = "" } = Astro.props;
---

<section id={id} class={`py-20 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto scroll-mt-16 ${className}`}>
  {title && (
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl mb-4 italic-">{title}</h2>
      {subtitle && <p class="text-lg text-gray-600 max-w-3xl">{subtitle}</p>}
      <div class="h-1.5 w-20 bg-blue-600 rounded-full mt-4"></div>
    </div>
  )}
  <slot />
</section>
