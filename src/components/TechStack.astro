---
import Section from './Section.astro';
import { profile } from '../../Profile.js';

// Since they aren't categorized in Profile.js, we'll map them.
const skills = profile.habilidades.map(skill => ({
  name: skill,
  category: 'Habilidades Técnicas'
}));

const categories = [...new Set(skills.map(s => s.category))];
---

<Section id="tech-stack" title="Tech Stack" subtitle="Tecnologías y herramientas que utilizo para dar vida a los proyectos.">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
    {categories.map(category => (
      <div class="bg-slate-800/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-700/50 shadow-xl text-center">
        <h4 class="text-blue-400 font-bold mb-8 uppercase tracking-widest text-sm">{category}</h4>
        <div class="flex flex-wrap gap-4 justify-center">
          {skills.filter(s => s.category === category).map(skill => (
            <span class="px-5 py-2.5 bg-slate-900/50 text-slate-300 rounded-xl text-sm font-semibold border border-slate-700 hover:border-blue-500 hover:text-blue-400 hover:shadow-[0_0_15px_rgba(59,130,246,0.2)] transition-all cursor-default transform hover:-translate-y-0.5">
               {skill.name}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>
